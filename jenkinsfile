pipeline {
    agent any
 
    // ─── Environment Variables ───────────────────────────────────────────────
    environment {
        MASTER_URL     = 'http://localhost:3000'
        WEBHOOK_SECRET = credentials('webhook-secret')   // stored in Jenkins credentials
        NODE_ENV       = 'production'
        JAVA_HOME      = '/usr/lib/jvm/java-17-openjdk'
        PYTHON_VERSION = '3.11'
    }
 
    // ─── Pipeline-level options ───────────────────────────────────────────────
    options {
        timeout(time: 30, unit: 'MINUTES')       // kill stuck builds after 30 min
        retry(1)                                  // retry once on failure
        timestamps()                              // prefix every log line with time
        disableConcurrentBuilds()                 // one build at a time per branch
        buildDiscarder(logRotator(
            numToKeepStr: '20',                   // keep last 20 build logs
            artifactNumToKeepStr: '5'
        ))
    }
 
    // ─── Triggers ─────────────────────────────────────────────────────────────
    triggers {
        githubPush()                              // fires on every git push via webhook
    }
 
    // ─── Parameters (manual run options) ─────────────────────────────────────
    parameters {
        choice(
            name: 'WORKER_LANGUAGE',
            choices: ['auto', 'Python', 'Java', 'JavaScript', 'Generic'],
            description: 'Force a specific worker language (auto = detect from repo)'
        )
        booleanParam(
            name: 'SKIP_TESTS',
            defaultValue: false,
            description: 'Skip the Test stage (for hotfix deploys)'
        )
        booleanParam(
            name: 'FORCE_DEPLOY',
            defaultValue: false,
            description: 'Deploy even if tests fail'
        )
    }
 
    // ─── Stages ───────────────────────────────────────────────────────────────
    stages {
 
        // ── 1. DETECT LANGUAGE ─────────────────────────────────────────────
        stage('Detect Language') {
            steps {
                script {
                    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    echo "  SIMULATED JENKINS CI/CD PIPELINE"
                    echo "  Branch  : ${env.BRANCH_NAME ?: 'master'}"
                    echo "  Commit  : ${env.GIT_COMMIT?.take(8) ?: 'unknown'}"
                    echo "  Trigger : ${currentBuild.getBuildCauses()[0]?.shortDescription ?: 'manual'}"
                    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
 
                    if (params.WORKER_LANGUAGE != 'auto') {
                        env.DETECTED_LANG = params.WORKER_LANGUAGE
                        echo "[LANG] Forced language: ${env.DETECTED_LANG}"
                    } else {
                        // Detect from files in the repo
                        def pyFiles   = sh(script: 'find . -name "*.py"   -not -path "./.git/*" | wc -l', returnStdout: true).trim()
                        def javaFiles = sh(script: 'find . -name "*.java" -not -path "./.git/*" | wc -l', returnStdout: true).trim()
                        def jsFiles   = sh(script: 'find . -name "*.js"   -not -path "./.git/*" | wc -l', returnStdout: true).trim()
 
                        if (javaFiles.toInteger() > 0) {
                            env.DETECTED_LANG = 'Java'
                        } else if (pyFiles.toInteger() > 0) {
                            env.DETECTED_LANG = 'Python'
                        } else if (jsFiles.toInteger() > 0) {
                            env.DETECTED_LANG = 'JavaScript'
                        } else {
                            env.DETECTED_LANG = 'Generic'
                        }
                        echo "[LANG] Auto-detected: ${env.DETECTED_LANG} (py=${pyFiles}, java=${javaFiles}, js=${jsFiles})"
                    }
 
                    // Set priority based on branch
                    env.JOB_PRIORITY = (env.BRANCH_NAME in ['master', 'main']) ? 'HIGH' : 'NORMAL'
                    echo "[PRIORITY] Branch '${env.BRANCH_NAME}' → ${env.JOB_PRIORITY} priority"
                }
            }
        }
 
        // ── 2. CHECKOUT ────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo "[CHECKOUT] Pulling latest code from ${env.GIT_URL ?: 'repository'}..."
                checkout scm
                script {
                    env.GIT_AUTHOR  = sh(script: 'git log -1 --format="%an"',  returnStdout: true).trim()
                    env.GIT_MESSAGE = sh(script: 'git log -1 --format="%s"',   returnStdout: true).trim()
                    env.GIT_SHA     = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    echo "[CHECKOUT] ✅ Commit ${env.GIT_SHA} by ${env.GIT_AUTHOR}: '${env.GIT_MESSAGE}'"
                }
            }
        }
 
        // ── 3. INSTALL DEPENDENCIES ────────────────────────────────────────
        stage('Install Dependencies') {
            parallel {
 
                stage('Python: Install') {
                    when {
                        expression { env.DETECTED_LANG == 'Python' }
                    }
                    steps {
                        echo "[WORKER-1 / PyWorker] Installing Python dependencies..."
                        sh '''
                            python3 --version
                            if [ -f requirements.txt ]; then
                                pip3 install -r requirements.txt --quiet
                                echo "✅ requirements.txt installed"
                            else
                                echo "ℹ️  No requirements.txt found — skipping pip install"
                            fi
                        '''
                    }
                }
 
                stage('Java: Install') {
                    when {
                        expression { env.DETECTED_LANG == 'Java' }
                    }
                    steps {
                        echo "[WORKER-3 / JavaWorker] Resolving Java dependencies..."
                        sh '''
                            java -version
                            if [ -f pom.xml ]; then
                                echo "Maven project detected"
                                mvn dependency:resolve -q
                                echo "✅ Maven dependencies resolved"
                            elif [ -f build.gradle ]; then
                                echo "Gradle project detected"
                                ./gradlew dependencies --quiet
                                echo "✅ Gradle dependencies resolved"
                            else
                                echo "ℹ️  No pom.xml or build.gradle — skipping"
                            fi
                        '''
                    }
                }
 
                stage('JS: Install') {
                    when {
                        expression { env.DETECTED_LANG == 'JavaScript' }
                    }
                    steps {
                        echo "[WORKER-2 / NodeWorker] Installing Node.js dependencies..."
                        sh '''
                            node --version
                            npm --version
                            if [ -f package.json ]; then
                                npm ci --prefer-offline --quiet
                                echo "✅ npm packages installed"
                            else
                                echo "ℹ️  No package.json found"
                            fi
                        '''
                    }
                }
 
                stage('Generic: Install') {
                    when {
                        expression { env.DETECTED_LANG == 'Generic' }
                    }
                    steps {
                        echo "[WORKER-4 / GenWorker] No specific language — running generic install..."
                        sh 'echo "✅ Generic install complete (no-op)"'
                    }
                }
            }
        }
 
        // ── 4. BUILD ───────────────────────────────────────────────────────
        stage('Build') {
            steps {
                script {
                    echo "[BUILD] Starting build for ${env.DETECTED_LANG} project..."
 
                    if (env.DETECTED_LANG == 'Python') {
                        sh '''
                            echo "[PyWorker] Compiling Python bytecode..."
                            python3 -m compileall . -q 2>/dev/null || true
                            echo "[PyWorker] ✅ Python build complete"
                        '''
                    } else if (env.DETECTED_LANG == 'Java') {
                        sh '''
                            echo "[JavaWorker] Compiling Java sources..."
                            if [ -f pom.xml ]; then
                                mvn compile -q
                            elif [ -f build.gradle ]; then
                                ./gradlew compileJava --quiet
                            else
                                # Direct javac if no build tool
                                find . -name "*.java" -not -path "./.git/*" > sources.txt
                                javac @sources.txt -d out/ 2>/dev/null || mkdir -p out && javac *.java -d out/
                            fi
                            echo "[JavaWorker] ✅ Java build complete"
                        '''
                    } else if (env.DETECTED_LANG == 'JavaScript') {
                        sh '''
                            echo "[NodeWorker] Building Node.js app..."
                            if [ -f package.json ] && grep -q '"build"' package.json; then
                                npm run build --if-present
                            fi
                            echo "[NodeWorker] ✅ Node.js build complete"
                        '''
                    } else {
                        sh 'echo "[GenWorker] ✅ Generic build — nothing to compile"'
                    }
                }
            }
        }
 
        // ── 5. TEST ────────────────────────────────────────────────────────
        stage('Test') {
            when {
                expression { return !params.SKIP_TESTS }
            }
            steps {
                script {
                    echo "[TEST] Running test suite for ${env.DETECTED_LANG}..."
 
                    if (env.DETECTED_LANG == 'Python') {
                        sh '''
                            echo "[PyWorker] Running Python tests..."
                            if [ -f pytest.ini ] || [ -d tests/ ] || [ -d test/ ]; then
                                python3 -m pytest --tb=short -q 2>/dev/null || echo "⚠️  pytest not available, running unittest..."
                                python3 -m unittest discover -s . -p "test_*.py" -q 2>/dev/null || true
                            else
                                echo "ℹ️  No test directory found — simulating test pass"
                                sleep 1
                            fi
                            echo "[PyWorker] ✅ Tests complete"
                        '''
                    } else if (env.DETECTED_LANG == 'Java') {
                        sh '''
                            echo "[JavaWorker] Running Java tests..."
                            if [ -f pom.xml ]; then
                                mvn test -q 2>/dev/null || true
                            elif [ -f build.gradle ]; then
                                ./gradlew test --quiet 2>/dev/null || true
                            else
                                echo "ℹ️  No test runner found — simulating test pass"
                                sleep 1
                            fi
                            echo "[JavaWorker] ✅ Tests complete"
                        '''
                    } else if (env.DETECTED_LANG == 'JavaScript') {
                        sh '''
                            echo "[NodeWorker] Running JS tests..."
                            if [ -f package.json ] && grep -q '"test"' package.json; then
                                npm test --if-present 2>/dev/null || true
                            else
                                echo "ℹ️  No test script — simulating test pass"
                                sleep 1
                            fi
                            echo "[NodeWorker] ✅ Tests complete"
                        '''
                    } else {
                        sh '''
                            echo "[GenWorker] Generic test — simulating..."
                            sleep 1
                            echo "✅ Generic test pass"
                        '''
                    }
                }
            }
        }
 
        // ── 6. REPORT TO MASTER ────────────────────────────────────────────
        stage('Report to Master') {
            steps {
                script {
                    echo "[PIPELINE] Reporting build result to Jenkins Master..."
                    def payload = """
                    {
                        "repo":       "${env.JOB_NAME}",
                        "language":   "${env.DETECTED_LANG}",
                        "branch":     "${env.BRANCH_NAME ?: 'master'}",
                        "commit_msg": "${env.GIT_MESSAGE?.replace('"', '\\"')}",
                        "pusher":     "${env.GIT_AUTHOR}",
                        "build_url":  "${env.BUILD_URL}",
                        "build_num":  "${env.BUILD_NUMBER}",
                        "priority":   "${env.JOB_PRIORITY}"
                    }
                    """.stripIndent()
 
                    // POST to your simulated Jenkins Master
                    sh """
                        curl -s -X POST ${MASTER_URL}/simulate-push \\
                             -H 'Content-Type: application/json' \\
                             -d '${payload.replaceAll("\\n", "").trim()}' \\
                             || echo "⚠️  Master unreachable — continuing anyway"
                    """
                    echo "[PIPELINE] ✅ Master notified"
                }
            }
        }
 
        // ── 7. DEPLOY ──────────────────────────────────────────────────────
        stage('Deploy') {
            when {
                anyOf {
                    branch 'master'
                    branch 'main'
                    expression { return params.FORCE_DEPLOY }
                }
            }
            steps {
                script {
                    echo "[DEPLOY] Deploying ${env.DETECTED_LANG} app from branch ${env.BRANCH_NAME}..."
                    echo "[DEPLOY] Build   : #${env.BUILD_NUMBER}"
                    echo "[DEPLOY] Commit  : ${env.GIT_SHA}"
                    echo "[DEPLOY] Author  : ${env.GIT_AUTHOR}"
                    echo "[DEPLOY] Priority: ${env.JOB_PRIORITY}"
 
                    // Simulated deploy step — replace with real deploy command
                    sh '''
                        echo "📦 Packaging artifact..."
                        sleep 1
                        echo "🚀 Deploying to environment..."
                        sleep 1
                        echo "✅ Deploy successful"
                    '''
                }
            }
        }
    }
 
    // ─── Post Actions ─────────────────────────────────────────────────────────
    post {
 
        always {
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "  BUILD COMPLETE"
            echo "  Status   : ${currentBuild.currentResult}"
            echo "  Language : ${env.DETECTED_LANG ?: 'unknown'}"
            echo "  Duration : ${currentBuild.durationString}"
            echo "  Branch   : ${env.BRANCH_NAME ?: 'master'}"
            echo "  Commit   : ${env.GIT_SHA ?: 'unknown'}"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        }
 
        success {
            echo "✅ Pipeline PASSED — Worker: ${env.DETECTED_LANG} | Commit: ${env.GIT_SHA}"
            // Notify master of success
            sh """
                curl -s -X POST ${MASTER_URL}/api/jobs/meta/notify \\
                     -H 'Content-Type: application/json' \\
                     -d '{"status":"SUCCESS","build":"${env.BUILD_NUMBER}","lang":"${env.DETECTED_LANG}"}' \\
                     || true
            """
        }
 
        failure {
            echo "❌ Pipeline FAILED — Check logs at ${env.BUILD_URL}"
            sh """
                curl -s -X POST ${MASTER_URL}/api/jobs/meta/notify \\
                     -H 'Content-Type: application/json' \\
                     -d '{"status":"FAILURE","build":"${env.BUILD_NUMBER}","lang":"${env.DETECTED_LANG}"}' \\
                     || true
            """
        }
 
        unstable {
            echo "⚠️  Pipeline UNSTABLE — Tests may have failed"
        }
 
        aborted {
            echo "🚫 Pipeline ABORTED — Job was cancelled or timed out"
        }
    }
}
 